{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint pharmacy/ --ext .js",
    "lint:fix": "eslint pharmacy/ --ext .js --fix",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=unit --runInBand --forceExit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=integration --runInBand --forceExit",
    "test:pharmacy": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=pharmacy --runInBand --forceExit",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=e2e --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 120000,
    "moduleNameMapper": {
      "^.*/pharmacy/pgClient\\.js$": "<rootDir>/pharmacy/__mocks__/pgClient.js"
    }
  },
  "mongodbMemoryServer": {
    "version": "7.0.14",
    "downloadDir": "./tests/.mongodb-binaries"
  },
  "author": "Anurag",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "mongoose-sequence": "^6.0.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.1",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2"
  }
}
