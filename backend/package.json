{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=unit --runInBand --forceExit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=integration --runInBand --forceExit",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=e2e --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 60000
  },
  "mongodbMemoryServer": {
    "version": "7.0.14",
    "downloadDir": "./tests/.mongodb-binaries"
  },
  "author": "Anurag",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "mongoose-sequence": "^6.0.1",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "cross-env": "^7.0.3",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.1.0",
    "supertest": "^7.2.2"
  }
